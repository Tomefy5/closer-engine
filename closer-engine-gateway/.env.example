# ============================================================
# .env.example — Variables d'environnement pour Closer Engine
# Copiez ce fichier en .env et renseignez vos vraies valeurs.
# NE JAMAIS committer le fichier .env dans git !
# ============================================================

# --- Meta / WhatsApp Business API ---
# Token de vérification que vous choisissez lors de la configuration
# du webhook dans le Meta Developer Portal.
META_VERIFY_TOKEN=mon_token_de_verification_factice

# Token d'accès permanent généré dans le Meta Developer Portal
# (System User Token ou Page Access Token).
META_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Paramètres de l'application (optionnels) ---
APP_NAME=Closer Engine
APP_VERSION=0.1.0
DEBUG=false
